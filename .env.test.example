# Configuration du serveur GeoNature de test pour les tests d'intégration
# Copier ce fichier vers .env.test et remplir avec les vraies valeurs

# URL du serveur GeoNature de test
TEST_SERVER_URL=https://geonature-test.example.com

# Credentials de test
TEST_USERNAME=your_test_username
TEST_PASSWORD=your_test_password

# Modules disponibles sur le serveur de test (séparés par des virgules)
TEST_MODULES=POPAmphibien,POPReptile
