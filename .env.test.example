# Configuration du serveur GeoNature de test pour les tests d'integration
# Copier ce fichier vers .env.test (local) ou .env.test.remote (serveur distant)
# et remplir avec les vraies valeurs. Tous les .env.test* sont gitignored.

# URL du serveur GeoNature de test
# - Emulateur Android sur GN local : http://10.0.2.2:8001
# - Appareil physique via adb reverse : http://127.0.0.1:8001
# - Serveur distant : https://geonature-test.example.com
TEST_SERVER_URL=https://geonature-test.example.com

# Credentials de test
TEST_USERNAME=your_test_username
TEST_PASSWORD=your_test_password

# Modules a tester (CSV). Le script itere les scenarios mono-module sur
# chaque entree. Le scenario cross-module lit toute la liste en une session.
TEST_MODULE_CODES=POPAmphibien,POPReptile

# Legacy (si TEST_MODULE_CODES est absent, ce champ est utilise comme fallback)
# TEST_MODULE_CODE=POPAmphibien

# Active l'etape d'upload dans les scenarios qui le supportent (many-taxa,
# cross-module). Equivaut au flag --with-upload du script.
# TEST_WITH_UPLOAD=false
